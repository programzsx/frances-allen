[Unit]
Description=Frances Allen Backend Service
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/frances-allen/server
EnvironmentFile=/opt/frances-allen/server/.env
ExecStart=/opt/frances-allen/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
